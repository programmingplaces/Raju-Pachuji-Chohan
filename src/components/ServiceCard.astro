---
interface Props {
  title: string;
  description: string;
  link?: string;
  icon?: string;
  benefits?: string[];
}

const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

const { 
  title, 
  description, 
  link = `${baseUrl}services`, 
  icon = "awning", 
  benefits = [] 
} = Astro.props;

// SVG Icons mapping for neat display without external libraries
const icons: Record<string, string> = {
  awning: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />`,
  tensile: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />`,
  sheds: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />`,
  roofing: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />`,
  canopy: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />`,
  commercial: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />`
};

const defaultIcon = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />`;
const selectedIcon = icons[icon] || defaultIcon;
---

<div class="scroll-trigger opacity-0 flex flex-col justify-between bg-white p-8 rounded-2xl border border-gray-100 shadow-sm hover:shadow-xl hover:border-gray-200 transition-all duration-300 transform hover:-translate-y-1">
  <div>
    <!-- Icon Container -->
    <div class="inline-flex items-center justify-center p-3 rounded-xl bg-secondary/10 text-secondary mb-6">
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" fragment={selectedIcon} set:html={selectedIcon} />
    </div>

    <!-- Title & Description -->
    <h3 class="text-xl font-bold text-primary mb-3 font-display">
      {title}
    </h3>
    <p class="text-sm text-gray-600 leading-relaxed mb-6">
      {description}
    </p>

    <!-- Key Benefits List -->
    {benefits.length > 0 && (
      <ul class="space-y-2 mb-8">
        {benefits.slice(0, 3).map(benefit => (
          <li class="flex items-center text-xs text-gray-500 font-semibold">
            <svg class="h-4 w-4 mr-2 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            {benefit}
          </li>
        ))}
      </ul>
    )}
  </div>

  <!-- Learn More CTA Link -->
  <div>
    <a 
      href={link} 
      class="inline-flex items-center text-sm font-bold text-secondary hover:text-secondary/80 group/link"
    >
      Learn More 
      <svg class="ml-1 h-4 w-4 transform group-hover/link:translate-x-1 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</div>
