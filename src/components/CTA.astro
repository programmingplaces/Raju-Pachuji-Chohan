---
interface Props {
  title?: string;
  description?: string;
  primaryButtonText?: string;
  primaryButtonLink?: string;
}

const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

const {
  title = "Ready to Install Premium Shade Solutions?",
  description = "Get in touch with Raju Pachuji Chohan for free site measurement, layout estimation, and high-quality structural installation in Mumbai & surrounding areas.",
  primaryButtonText = "Request Free Inspection",
  primaryButtonLink = `${baseUrl}contact`
} = Astro.props;
---

<section class="bg-primary relative overflow-hidden py-16 sm:py-20 border-y border-white/5">
  <!-- Subtle Background Accents -->
  <div class="absolute inset-0 opacity-5 bg-[radial-gradient(#eab308_1px,transparent_1px)] [background-size:16px_16px]"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-80 bg-secondary/15 rounded-full blur-[80px] pointer-events-none"></div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center space-y-6">
    <span class="text-xs tracking-widest text-accent font-bold uppercase">
      Fast Response & High Quality
    </span>
    
    <h2 class="text-3xl sm:text-4xl font-extrabold text-white font-display">
      {title}
    </h2>
    
    <p class="text-base sm:text-lg text-gray-300 max-w-2xl mx-auto leading-relaxed">
      {description}
    </p>

    <!-- CTAs Stacked on mobile, side-by-side on desktop -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
      <!-- Direct Form Action -->
      <a 
        href={primaryButtonLink} 
        class="w-full sm:w-auto inline-flex items-center justify-center px-6 py-3.5 border border-transparent rounded-lg shadow-md text-sm font-bold text-white bg-secondary hover:bg-secondary/90 transition-all duration-200"
      >
        {primaryButtonText}
      </a>

      <!-- Direct Phone Action -->
      <a 
        href="tel:+919768690579" 
        class="w-full sm:w-auto inline-flex items-center justify-center px-6 py-3.5 border border-white/20 rounded-lg text-sm font-bold text-white hover:bg-white/10 transition-all duration-200"
      >
        <svg class="h-4 w-4 mr-2 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call +91 97686 90579
      </a>

      <!-- WhatsApp CTA -->
      <a 
        href="https://wa.me/919768690579?text=I%20want%20to%20request%20a%20site%20inspection%20for%20Awnings/Canopies." 
        target="_blank" 
        rel="noopener noreferrer" 
        class="w-full sm:w-auto inline-flex items-center justify-center px-6 py-3.5 border border-green-500/30 bg-green-500/10 hover:bg-green-500/25 rounded-lg text-sm font-bold text-green-400 transition-all duration-200"
      >
        Chat on WhatsApp
      </a>
    </div>
  </div>
</section>
