---
interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaLink?: string;
}

const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

const { 
  title = "Premium Awnings, Canopies & Tensile Structures",
  subtitle = "Enhance your outdoor spaces with durable, custom-designed shades, roofing, and structural solutions in Mumbai.",
  ctaText = "Get Free Quote",
  ctaLink = `${baseUrl}contact`
} = Astro.props;
---

<div class="relative bg-primary overflow-hidden min-h-[85vh] flex items-center">
  <!-- Decorative Grid Overlay -->
  <div class="absolute inset-0 opacity-10 bg-[linear-gradient(to_right,#808080_1px,transparent_1px),linear-gradient(to_bottom,#808080_1px,transparent_1px)] bg-[size:24px_24px]"></div>
  
  <!-- Ambient Gradient Light -->
  <div class="absolute top-1/4 left-1/4 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-secondary/20 rounded-full blur-[100px] pointer-events-none"></div>
  <div class="absolute bottom-1/4 right-1/4 translate-x-1/2 translate-y-1/2 w-96 h-96 bg-accent/10 rounded-full blur-[120px] pointer-events-none"></div>

  <!-- Diagonal Highlight/Background SVG -->
  <div class="absolute right-0 bottom-0 top-0 w-1/2 hidden lg:flex items-center justify-center pointer-events-none opacity-25">
    <svg class="w-full h-full text-secondary/40" viewBox="0 0 100 100" preserveAspectRatio="none" fill="currentColor">
      <path d="M100 0 L50 100 L100 100 Z" />
    </svg>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 relative z-10 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      
      <!-- Text Content Area -->
      <div class="lg:col-span-7 space-y-6 text-left animate-fade-in">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-secondary/20 text-secondary border border-secondary/30 uppercase tracking-widest">
          ESTABLISHED SHADE EXPERTS
        </span>
        
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight font-display">
          {title.split(' ').map((word, idx) => {
            const highlightWords = ["Awnings,", "Canopies", "Structures", "Tensile", "Shades"];
            const cleanWord = word.replace(/[^a-zA-Z,]/g, "");
            const isHighlight = highlightWords.includes(cleanWord);
            return (
              <span class={isHighlight ? "text-secondary block sm:inline" : "text-white"}>
                {word}{' '}
              </span>
            );
          })}
        </h1>
        
        <p class="text-lg sm:text-xl text-gray-300 max-w-2xl leading-relaxed">
          {subtitle}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <!-- Primary CTA: Contact Form / Quote -->
          <a 
            href={ctaLink} 
            class="inline-flex items-center justify-center px-8 py-4 border border-transparent rounded-lg shadow-xl text-base font-bold text-white bg-secondary hover:bg-secondary/90 transition-all duration-200 transform hover:-translate-y-0.5 active:translate-y-0"
          >
            {ctaText}
            <svg class="ml-2 -mr-1 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>

          <!-- Secondary CTA: Call Now -->
          <a 
            href="tel:+919768690579" 
            class="inline-flex items-center justify-center px-8 py-4 border-2 border-white/20 rounded-lg text-base font-bold text-white hover:bg-white/10 hover:border-white transition-all duration-200"
          >
            <svg class="mr-2 h-5 w-5 text-accent animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call +91 97686 90579
          </a>
        </div>

        <!-- Trust Badges -->
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 pt-8 border-t border-white/10 max-w-lg">
          <div>
            <p class="text-xl sm:text-2xl font-extrabold text-accent">15+ Years</p>
            <p class="text-xs text-gray-400 font-semibold uppercase tracking-wider">Experience</p>
          </div>
          <div>
            <p class="text-xl sm:text-2xl font-extrabold text-accent">1000+</p>
            <p class="text-xs text-gray-400 font-semibold uppercase tracking-wider">Projects Done</p>
          </div>
          <div class="col-span-2 sm:col-span-1">
            <p class="text-xl sm:text-2xl font-extrabold text-accent">100%</p>
            <p class="text-xs text-gray-400 font-semibold uppercase tracking-wider">Quality Material</p>
          </div>
        </div>
      </div>

      <!-- Right Side Visual Showcase -->
      <div class="lg:col-span-5 relative hidden lg:block h-96">
        <!-- Main Image Frame with border -->
        <div class="absolute inset-0 rounded-2xl border-2 border-white/10 bg-white/5 backdrop-blur-sm shadow-2xl p-3 transform rotate-2 hover:rotate-0 transition-transform duration-500">
          <div class="relative w-full h-full rounded-xl overflow-hidden bg-primary/80 flex items-center justify-center">
            <!-- Simulated Architectural Canvas Drawing / Grid Pattern -->
            <svg class="absolute inset-0 w-full h-full opacity-20 text-white" fill="none" viewBox="0 0 100 100" stroke="currentColor">
              <path stroke-dasharray="2 2" d="M10,0 L10,100 M20,0 L20,100 M30,0 L30,100 M40,0 L40,100 M50,0 L50,100 M60,0 L60,100 M70,0 L70,100 M80,0 L80,100 M90,0 L90,100" />
              <path stroke-dasharray="2 2" d="M0,10 L100,10 0,20 L100,20 0,30 L100,30 0,40 L100,40 0,50 L100,50 0,60 L100,60 0,70 L100,70 0,80 L100,80 0,90 L100,90" />
            </svg>
            
            <!-- Dynamic Vector of an Awning/Canopy Structure -->
            <svg class="w-3/4 h-3/4 text-secondary/80 animate-pulse" viewBox="0 0 200 150" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Wall/Structure anchor -->
              <line x1="20" y1="20" x2="20" y2="130" stroke="#E2E8F0" stroke-width="4" stroke-linecap="round"/>
              <line x1="15" y1="30" x2="25" y2="30" stroke="#E2E8F0" stroke-width="2"/>
              <line x1="15" y1="120" x2="25" y2="120" stroke="#E2E8F0" stroke-width="2"/>
              <!-- Canopy Frame -->
              <path d="M20 30 L170 80 L20 120 Z" stroke="currentColor" stroke-width="3" fill="currentColor" fill-opacity="0.1" stroke-linejoin="round"/>
              <!-- Support Struts -->
              <line x1="20" y1="75" x2="170" y2="80" stroke="#EAB308" stroke-width="2"/>
              <line x1="95" y1="52" x2="95" y2="98" stroke="#EAB308" stroke-width="1.5" stroke-dasharray="2 2"/>
              <!-- Drops / Valance detail -->
              <path d="M20 120 Q 35 125, 50 120 Q 65 125, 80 120 Q 95 125, 110 120 Q 125 125, 140 120 Q 155 125, 170 80" stroke="currentColor" stroke-width="2"/>
              <!-- Text label -->
              <text x="70" y="140" fill="#94A3B8" font-size="10" font-family="sans-serif" letter-spacing="1">DURABILITY ENGINE</text>
            </svg>
          </div>
        </div>

        <!-- Secondary accent element -->
        <div class="absolute -bottom-4 -left-4 w-32 h-32 bg-accent/20 rounded-xl border border-accent/30 -z-10 transform -rotate-12"></div>
      </div>

    </div>
  </div>
</div>
