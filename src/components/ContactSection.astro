---
const serviceAreas = [
  'Mumbai Central', 'Navi Mumbai', 'Thane City', 
  'Mira Road', 'Vasai Road', 'Virar'
];
---

<section class="py-16 bg-gray-50 scroll-trigger opacity-0">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-xs tracking-widest text-secondary font-bold uppercase">
        Have Questions?
      </span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-primary mt-2 font-display">
        Get in Touch With Us
      </h2>
      <p class="text-sm sm:text-base text-gray-600 mt-4">
        Fill out the quick quote form below or reach us directly on phone or WhatsApp. We reply within 2 hours.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      <!-- Contact Information Cards (5 Columns) -->
      <div class="lg:col-span-5 space-y-6">
        
        <!-- Call Card -->
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm flex items-start gap-4">
          <div class="p-3 bg-secondary/10 text-secondary rounded-xl">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-primary">Call Now</h3>
            <p class="text-sm text-gray-500 mt-1">For immediate estimation and queries</p>
            <a href="tel:+919768690579" class="text-lg font-bold text-secondary hover:text-secondary/80 mt-2 inline-block">
              +91 97686 90579
            </a>
          </div>
        </div>

        <!-- WhatsApp Card -->
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm flex items-start gap-4">
          <div class="p-3 bg-green-500/10 text-green-500 rounded-xl">
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.498 1.451 5.42 1.453 5.488 0 9.954-4.468 9.958-9.96.002-2.66-1.033-5.161-2.91-7.04C17.24 1.73 14.736.687 12.01.687c-5.49 0-9.958 4.469-9.96 9.96 0 1.983.518 3.918 1.5 5.632l-.98 3.578 3.676-.964zm11.232-7.513c-.3-.15-1.772-.875-2.04-.972-.269-.099-.465-.148-.659.15-.195.297-.753.951-.922 1.149-.169.198-.337.223-.638.073-.3-.15-1.268-.467-2.414-1.49-1.127-1.004-1.887-2.243-2.108-2.618-.222-.375-.024-.578.126-.727.135-.133.3-.35.45-.525.15-.175.2-.299.3-.499.1-.2.05-.375-.025-.524-.075-.15-.658-1.585-.902-2.172-.237-.57-.478-.492-.659-.501-.17-.008-.364-.01-.559-.01-.195 0-.514.073-.783.37-.269.297-1.026 1.004-1.026 2.447 0 1.443 1.05 2.837 1.196 3.035.147.198 2.068 3.159 5.011 4.434.7.303 1.246.484 1.671.62.703.224 1.344.193 1.85.117.564-.085 1.772-.726 2.022-1.428.25-.702.25-1.303.175-1.428-.075-.125-.269-.199-.57-.349z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-primary">WhatsApp Us</h3>
            <p class="text-sm text-gray-500 mt-1">Send photos/sizes for instant estimation</p>
            <a 
              href="https://wa.me/919768690579?text=Hello%20Raju,%20I%20want%20to%20get%20a%20price%20quote%20for%20Awnings." 
              target="_blank" 
              rel="noopener noreferrer" 
              class="text-lg font-bold text-green-500 hover:text-green-600 mt-2 inline-block"
            >
              Start Chat
            </a>
          </div>
        </div>

        <!-- Service Area Card -->
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm space-y-3">
          <h3 class="text-lg font-bold text-primary">Service Locations</h3>
          <p class="text-sm text-gray-500">We operate extensively in the following regions:</p>
          <div class="flex flex-wrap gap-2 pt-1">
            {serviceAreas.map(area => (
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">
                📍 {area}
              </span>
            ))}
          </div>
        </div>

      </div>

      <!-- Contact Form Container (7 Columns) -->
      <div class="lg:col-span-7 bg-white p-8 rounded-2xl border border-gray-100 shadow-md">
        <h3 class="text-xl font-bold text-primary mb-6 font-display">Send a Message</h3>
        
        <form id="contact-form" class="space-y-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-2">Your Name *</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-all"
                placeholder="Rohan Sharma"
              />
            </div>
            <div>
              <label for="phone" class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-2">Phone Number *</label>
              <input 
                type="tel" 
                id="phone" 
                name="phone" 
                required
                pattern="[0-9]{10}"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-all"
                placeholder="9876543210"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="email" class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-2">Email (Optional)</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-all"
                placeholder="rohan@example.com"
              />
            </div>
            <div>
              <label for="service" class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-2">Service Needed *</label>
              <select 
                id="service" 
                name="service" 
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary bg-white transition-all"
              >
                <option value="">Select a service</option>
                <option value="awning">Awning Installation</option>
                <option value="tensile">Tensile Structures</option>
                <option value="parking">Parking Sheds</option>
                <option value="polycarbonate">Polycarbonate Roofing</option>
                <option value="canopy">Fabric Canopies</option>
                <option value="retractable">Retractable Awnings</option>
                <option value="other">Other Shade Solutions</option>
              </select>
            </div>
          </div>

          <div>
            <label for="message" class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-2">Project Details / Message *</label>
            <textarea 
              id="message" 
              name="message" 
              rows="4" 
              required
              class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-all"
              placeholder="Please describe your requirements (e.g. size, location, type of canopy)..."
            ></textarea>
          </div>

          <div>
            <button 
              type="submit" 
              class="w-full inline-flex items-center justify-center px-6 py-4 border border-transparent rounded-lg shadow-md text-base font-bold text-white bg-secondary hover:bg-secondary/90 transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-secondary"
            >
              Submit Quote Request
            </button>
          </div>
        </form>

        <!-- Form Success Indicator -->
        <div id="form-success" class="hidden mt-6 p-4 bg-green-50 border border-green-200 rounded-lg text-green-700 text-sm font-semibold flex items-center">
          <svg class="h-5 w-5 mr-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Thank you! Your quote request has been sent. Raju Pachuji Chohan will contact you shortly.
        </div>

      </div>

    </div>
  </div>
</section>

<script>
  // Simple frontend submission handler
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successIndicator = document.getElementById('form-success');

  if (form && successIndicator) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      // Simulate form submission
      setTimeout(() => {
        form.reset();
        successIndicator.classList.remove('hidden');
        
        // Hide indicator after 7 seconds
        setTimeout(() => {
          successIndicator.classList.add('hidden');
        }, 7000);
      }, 800);
    });
  }
</script>
