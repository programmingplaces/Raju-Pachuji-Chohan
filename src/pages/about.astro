---
import MainLayout from '../layouts/MainLayout.astro';
import CTA from '../components/CTA.astro';

const values = [
  {
    title: "Uncompromising Quality",
    desc: "We use top-tier structural fabrics (PVDF, PTFE) and hot-dip galvanized steel frames to ensure each installation is rust-proof and storm-resistant."
  },
  {
    title: "Customer-First Engineering",
    desc: "Every canopy, awning, or parking shed is tailored to the customer's specific dimensions, site constraints, and design preferences."
  },
  {
    title: "Timely Implementation",
    desc: "We respect your schedule. Our streamlined in-house fabrication ensures swift installations across Mumbai, Thane, and Navi Mumbai."
  },
  {
    title: "15+ Years of Trust",
    desc: "Led by Raju Pachuji Chohan, we combine old-school manufacturing standards with modern architectural shade styles."
  }
];
---

<MainLayout
  title="About Us | Raju Pachuji Chohan Awnings & Canopies Mumbai"
  description="Learn about our 15+ years of experience in manufacturing premium awnings, tensile shade structures, and polycarbonate roofing in Mumbai. Led by Raju Pachuji Chohan."
  keywords="about raju pachuji chohan, awning manufacturer mumbai, canopy engineering, tensile structures experience"
>

  <!-- Title Banner Section -->
  <section class="bg-primary text-white py-16 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[linear-gradient(to_right,#808080_1px,transparent_1px),linear-gradient(to_bottom,#808080_1px,transparent_1px)] bg-[size:30px_30px]"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <span class="text-xs font-bold uppercase tracking-widest text-accent">Our Heritage</span>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mt-2 font-display">
        About Our Company
      </h1>
      <p class="text-gray-300 mt-4 max-w-2xl text-base sm:text-lg">
        Building durable, modern, and beautiful shade systems across Mumbai for residential and commercial customers.
      </p>
    </div>
  </section>

  <!-- Detailed Story & Experience -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Story Copy -->
        <div class="space-y-6">
          <h2 class="text-2xl sm:text-3xl font-bold text-primary font-display">
            A Legacy of Shading Excellence
          </h2>
          <p class="text-sm sm:text-base text-gray-600 leading-relaxed">
            Founded with a passion for quality construction, our firm under the management of **Raju Pachuji Chohan** has grown from a local awning installer to a leading fabricator of complex architectural tensile structures, multi-vehicle parking sheds, and commercial canopies in Mumbai.
          </p>
          <p class="text-sm sm:text-base text-gray-600 leading-relaxed">
            We understand the challenges of Mumbai's weather. High summer temperatures followed by torrential monsoon downpours require structures that are engineered with precision. That is why we source only UV-coated, waterproof, and heat-blocking membranes and pair them with heavily braced galvanized steel framing.
          </p>

          <div class="p-6 bg-gray-50 border-l-4 border-secondary rounded-r-xl space-y-2">
            <p class="text-sm italic text-gray-700 font-semibold">
              "We don't just sell awnings; we engineering customized spaces. A restaurant cover must withstand coastal winds; a parking shed must protect paintwork from heavy heat. Our commitment is delivering long-term security."
            </p>
            <p class="text-xs font-bold text-primary">— Raju Pachuji Chohan, Founder</p>
          </div>
        </div>

        <!-- Visual / Experience Grid -->
        <div class="grid grid-cols-2 gap-6">
          <div class="bg-gray-100 p-8 rounded-2xl border border-gray-200 text-center flex flex-col justify-center shadow-sm">
            <span class="text-4xl sm:text-5xl font-extrabold text-secondary">15+</span>
            <span class="text-xs uppercase font-bold text-primary mt-2 tracking-wider">Years Experience</span>
          </div>
          <div class="bg-primary text-white p-8 rounded-2xl border border-white/5 text-center flex flex-col justify-center shadow-sm">
            <span class="text-4xl sm:text-5xl font-extrabold text-accent">1,000+</span>
            <span class="text-xs uppercase font-bold text-gray-300 mt-2 tracking-wider">Happy Clients</span>
          </div>
          <div class="bg-primary text-white p-8 rounded-2xl border border-white/5 text-center flex flex-col justify-center shadow-sm col-span-2">
            <span class="text-xl sm:text-2xl font-bold text-white">Mumbai, Thane, Navi Mumbai, Mira Road, Vasai, Virar</span>
            <span class="text-xs uppercase font-bold text-accent mt-2 tracking-wider block">Areas Served</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        
        <!-- Mission -->
        <div class="bg-white p-8 rounded-2xl border border-gray-100 shadow-sm space-y-4">
          <div class="h-10 w-10 bg-secondary/10 text-secondary rounded-lg flex items-center justify-center font-bold text-xl">
            🎯
          </div>
          <h3 class="text-xl font-bold text-primary font-display">Our Mission</h3>
          <p class="text-sm text-gray-600 leading-relaxed">
            To provide commercial and residential spaces with architectural shading solutions that are exceptionally durable, aesthetically superior, and cost-effective. We aim to protect people, vehicles, and businesses from harsh weather elements through honest workmanship and high-quality materials.
          </p>
        </div>

        <!-- Vision -->
        <div class="bg-white p-8 rounded-2xl border border-gray-100 shadow-sm space-y-4">
          <div class="h-10 w-10 bg-secondary/10 text-secondary rounded-lg flex items-center justify-center font-bold text-xl">
            👁️
          </div>
          <h3 class="text-xl font-bold text-primary font-display">Our Vision</h3>
          <p class="text-sm text-gray-600 leading-relaxed">
            To be recognized as the premier customer-centric manufacturer of tensile structures and canopy tents in Western India, famous for introducing modern structural styles, smart automation, and wind-durable framework designs.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Quality Commitment Details -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-xs tracking-widest text-secondary font-bold uppercase">Our Values</span>
        <h2 class="text-3xl font-bold text-primary mt-2 font-display">
          Guiding Principles of Our Craft
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {values.map(val => (
          <div class="p-6 border border-gray-100 rounded-xl space-y-3 hover:border-gray-200 hover:shadow-md transition-all">
            <h4 class="font-bold text-lg text-primary">{val.title}</h4>
            <p class="text-xs sm:text-sm text-gray-500 leading-relaxed">{val.desc}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <CTA />

</MainLayout>
