---
import MainLayout from '../layouts/MainLayout.astro';
import ContactSection from '../components/ContactSection.astro';
---

<MainLayout
  title="Contact Us | Raju Pachuji Chohan Awnings & Canopies Mumbai"
  description="Contact Raju Pachuji Chohan on +91 97686 90579 for a free site measurement and estimate. Direct phone, WhatsApp, and quote form. Areas: Mumbai, Thane."
  keywords="contact raju pachuji chohan, awning price quote, tensile structures mumbai phone, car parking shed estimate"
>

  <!-- Title Banner -->
  <section class="bg-primary text-white py-16 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[linear-gradient(to_right,#808080_1px,transparent_1px),linear-gradient(to_bottom,#808080_1px,transparent_1px)] bg-[size:30px_30px]"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <span class="text-xs font-bold uppercase tracking-widest text-accent">Reach Us</span>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mt-2 font-display">
        Contact Our Office
      </h1>
      <p class="text-gray-300 mt-4 max-w-2xl text-base sm:text-lg">
        Schedule a free on-site measurement or request a quote for awnings, canopies, and tensile structures.
      </p>
    </div>
  </section>

  <!-- Reusable Contact Section (Includes forms, phone, whatsapp, areas served) -->
  <ContactSection />

  <!-- Additional FAQ/Map Placeholder Area -->
  <section class="pb-16 bg-gray-50 border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Site Inspection info -->
        <div class="space-y-4">
          <h3 class="text-xl font-bold text-primary font-display">Free Site Visit & Inspection</h3>
          <p class="text-sm text-gray-600 leading-relaxed">
            We understand that custom shade structures require exact planning. That is why **Raju Pachuji Chohan** offers free visits within Mumbai, Navi Mumbai, Thane, Mira Road, Vasai, and Virar to:
          </p>
          <ul class="space-y-2 text-sm text-gray-600">
            <li class="flex items-center">
              <span class="text-secondary font-bold mr-2">✓</span> Take precise site measurements.
            </li>
            <li class="flex items-center">
              <span class="text-secondary font-bold mr-2">✓</span> Show physical catalogs and fabric swatches (waterproof, UV, translucent).
            </li>
            <li class="flex items-center">
              <span class="text-secondary font-bold mr-2">✓</span> Recommend layout configurations based on building wind-loads and sunlight angles.
            </li>
          </ul>
          <p class="text-xs text-gray-400 mt-2 font-semibold">
            * Visits are generally scheduled within 24-48 hours of your request.
          </p>
        </div>

        <!-- Simulated Map Box -->
        <div class="bg-white p-4 rounded-2xl border border-gray-200 shadow-md">
          <div class="bg-gray-100 rounded-xl w-full h-64 relative overflow-hidden flex items-center justify-center">
            <!-- Simulated Google Map vector/graphic -->
            <svg class="absolute inset-0 w-full h-full opacity-25 text-primary" fill="currentColor" viewBox="0 0 100 100" preserveAspectRatio="none">
              <path d="M0 20 L100 80 M0 50 L100 30 M30 0 L70 100 M60 0 L40 100" stroke="#1E293B" stroke-width="0.5"/>
              <circle cx="50" cy="50" r="8" fill="#F97316" fill-opacity="0.2"/>
              <circle cx="50" cy="50" r="3" fill="#F97316"/>
            </svg>
            <div class="text-center relative z-10 p-6 space-y-2">
              <span class="text-2xl">📍</span>
              <h4 class="font-bold text-primary">Service Center Mumbai</h4>
              <p class="text-xs text-gray-500 max-w-xs">Operating across Mumbai City, Suburbs, Thane & Navi Mumbai</p>
              <a 
                href="https://wa.me/919768690579?text=Send%20me%20your%20office%20location." 
                target="_blank" 
                rel="noopener noreferrer" 
                class="inline-block mt-2 text-xs text-secondary font-bold uppercase hover:underline"
              >
                Get Directions via WhatsApp
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</MainLayout>

<script>
  // Parse incoming service query parameter and pre-select the dropdown
  window.addEventListener('DOMContentLoaded', () => {
    const urlParams = new URLSearchParams(window.location.search);
    const serviceParam = urlParams.get('service');
    if (serviceParam) {
      const selectEl = document.getElementById('service') as HTMLSelectElement;
      if (selectEl) {
        // Pre-select target value
        const option = selectEl.querySelector(`option[value="${serviceParam}"]`);
        if (option) {
          selectEl.value = serviceParam;
        }
      }
    }
  });
</script>
